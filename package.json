{
  "name": "react-icons-root",
  "private": true,
  "workspaces": [
    "packages/*",
    "generated-packages/*"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.62.0"
  },
  "resolutions": {
    "@ungap/structured-clone": "1.3.2",
    "ajv@npm:^8.9.0": "8.20.0",
    "ajv@npm:^8.17.1": "8.20.0",
    "brace-expansion": "5.0.7",
    "encoding-sniffer": "1.0.2",
    "express": "4.22.2",
    "fast-uri": "4.1.0",
    "flatted": "3.4.2",
    "glob": "13.0.6",
    "handlebars": "4.7.9",
    "esbuild": "0.28.1",
    "js-yaml": "4.2.0",
    "minimatch": "10.2.5",
    "picomatch": "4.0.4",
    "qs": "6.15.3",
    "smol-toml": "1.7.0",
    "socks": "2.8.9",
    "tar": "7.5.19",
    "yaml": "2.9.0",
    "ws": "8.21.0"
  },
  "scripts": {
    "lint": "yarn eslint",
    "format": "prettier --write --ignore-unknown '**/*.{js,ts,mjs,cjs,json,astro}'",
    "format:ci": "prettier --check --ignore-unknown '**/*.{js,ts,mjs,cjs,json,astro}'",
    "version-up": "npx lerna@9.0.7 version",
    "version-snapshot": "npx lerna@9.0.7 version --no-push --no-git-tag-version --yes --preid snapshot prepatch --force-publish",
    "version": "yarn install && git add .",
    "lerna": "npx lerna@9.0.7"
  },
  "packageManager": "yarn@4.17.0"
}
