{
  "compilerOptions": {
    "outDir": "./build/lib",
    "emitDeclarationOnly": true,
    "rootDir": "./src",
    "module": "es2015",
    "target": "es2015",
    "lib": ["es2017", "dom"],
    "jsx": "react",
    "moduleResolution": "bundler",
    "declaration": true,
    "strict": true,
    "noImplicitAny": true
  },
  "include": ["src/**/*.tsx"],
  "exclude": ["icons"]
}
